# Copy to .env and fill in from the Supabase project dashboard (Settings → API).

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Optional: "true" = offline UI demo only (skips DB participant sync). Omit or false for real sessions.
# VITE_WSTUDIO_DEMO=true

# Optional: "true" = show experimental bridge output that sends PCM to the AU via localhost WebSocket.
# Default product path is W.STUDIO Desktop Bridge + virtual input, not this.
# VITE_WSTUDIO_PLUGIN_WS_BRIDGE=true

# Optional: port for W.STUDIO Desktop Bridge (Rust). Default 48001 — must match `npm run wstudio:bridge`.
# VITE_WSTUDIO_DESKTOP_BRIDGE_PORT=48001
